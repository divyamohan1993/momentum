# ─── Momentum env (committed with DUMMY values; real secrets live in Secret Manager) ───
# Identity / access (Deviation D1: owner passphrase gate, not Firebase Google sign-in)
OWNER_EMAIL=divyamohan1993@gmail.com
OWNER_PASSPHRASE_HASH=          # argon2id hash of the owner passphrase
SESSION_SECRET=                 # >=32 random bytes (base64url) — signs the session JWT
FIELD_KEY=                      # 32 random bytes (base64) — AES-256-GCM field encryption
EDGE_SECRET=                    # optional: shared secret injected by Cloudflare; when set,
                                # direct run.app hits without it get a static 403 (review B3)

# Brain (server-only; never in client bundle)
GEMINI_API_KEY=                 # generativelanguage API key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_DAILY_CAP=800            # in-app hard stop, well under free RPD

# Web Push (VAPID)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:divyamohan1993@gmail.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=   # public key is safe to ship to the client

# GCP / Firestore
GCP_PROJECT=dmjone
FIRESTORE_DATABASE=(default)
# Service account email allowed to call /api/sweep via OIDC (Cloud Scheduler)
SWEEP_INVOKER_SA=

# Runtime
TZ=Asia/Kolkata
NODE_ENV=development
